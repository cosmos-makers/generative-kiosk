{
  "name": "generative-kiosk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-dev} next dev",
    "prebuild": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "verify:runtime:soak": "RUNTIME_SOAK_CYCLES=6 node scripts/verify-runtime.mjs",
    "verify:runtime:report": "RUNTIME_VERIFY_REPORT_PATH=test-results/runtime-verify-report.json RUNTIME_VERIFY_HISTORY_PATH=.omx/logs/runtime-verify-history.json node scripts/verify-runtime.mjs",
    "verify:runtime:history-summary": "node -e \"const fs=require('fs'); const p='.omx/logs/runtime-verify-history.json'; const items=JSON.parse(fs.readFileSync(p,'utf8')); const latest=items.at(-1)||null; console.log(JSON.stringify({runs:items.length, latestGeneratedAt:latest?.generatedAt??null, allStable:items.every((x)=>x?.soak?.stable===true), maxCycles:items.reduce((m,x)=>Math.max(m, x?.soak?.cycles??0),0)}, null, 2));\"",
    "verify:evidence-summary": "node scripts/evidence-summary.mjs",
    "verify:readiness-report": "node scripts/readiness-report.mjs",
    "write:readiness-report": "node scripts/write-readiness-report.mjs",
    "write:handoff-note": "node scripts/handoff-note.mjs > test-results/handoff-note-latest.md",
    "collect:evidence-bundle": "node scripts/collect-evidence-bundle.mjs",
    "open:chrome": "node scripts/open-chrome.mjs",
    "init:manual-log": "node scripts/init-manual-log.mjs",
    "verify:all": "npm run typecheck && npm test && npm run lint && npm run build && npm run test:e2e && npm run verify:runtime:report && npm run verify:runtime:history-summary"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@mediapipe/tasks-vision": "^0.10.22",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "^14.2.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
