+const categoryTabs = document.querySelector("#categoryTabs");
+const menuGrid = document.querySelector("#menuGrid");
+const cartItems = document.querySelector("#cartItems");
+const cartCount = document.querySelector("#cartCount");
+const cartTotal = document.querySelector("#cartTotal");
+const resetButton = document.querySelector("#resetButton");
+const checkoutButton = document.querySelector("#checkoutButton");
+const statusMessage = document.querySelector("#statusMessage");
+
+let activeCategory = categories[0];
+let cartState = createCartState();
+
+function setStatus(message) {
+  statusMessage.textContent = message;
+}
+
+function getVisibleItems() {
+  return menuItems.filter((item) => item.category === activeCategory);
+}
+
+function renderCategoryTabs() {
+  categoryTabs.innerHTML = categories
+    .map(
+      (category) => `
+        <button
+          type="button"
+          class="category-tab ${category === activeCategory ? "active" : ""}"
+          data-category="${category}"
+        >
+          ${category}
+        </button>
+      `
+    )
+    .join("");
+}
+
+function renderMenu() {
+  menuGrid.innerHTML = getVisibleItems()
+    .map(
+      (item) => `
+        <article class="menu-card">
+          <div>
+            <h3>${item.name}</h3>
+            <p class="menu-description">${item.description}</p>
+          </div>
+          <div class="tag-row">
+            ${item.tags.map((tag) => `<span class="tag">${tag}</span>`).join("")}
+          </div>
+          <div class="menu-card-footer">
+            <span class="price">${formatWon(item.price)}</span>
+            <button type="button" class="primary-button" data-add-id="${item.id}">
+              담기
+            </button>
+          </div>
+        </article>
+      `
+    )
+    .join("");
+}
+
+function renderCart() {
+  const summary = getCartSummary(cartState);
+
+  cartCount.textContent = `${summary.count}개`;
+  cartTotal.textContent = formatWon(summary.total);
+
+  if (!cartState.items.length) {
+    cartItems.innerHTML = `
+      <div class="empty-cart">
+        아직 선택한 메뉴가 없어요.<br />
+        왼쪽에서 메뉴를 골라 장바구니에 담아보세요.
+      </div>
+    `;
+    return;
+  }
+
+  cartItems.innerHTML = cartState.items
+    .map(
+      (item) => `
+        <article class="cart-item">
+          <div class="cart-item-footer">
+            <div>
+              <h3>${item.name}</h3>
+              <p class="cart-item-meta">${formatWon(item.price)} / 1개</p>
+            </div>
+            <button type="button" class="remove-button" data-remove-id="${item.id}">
+              삭제
+            </button>
+          </div>
+          <div class="cart-item-footer">
+            <div class="quantity-controls">
+              <button type="button" class="quantity-button" data-change-id="${item.id}" data-delta="-1">
+                −
+              </button>
+              <strong>${item.quantity}</strong>
+              <button type="button" class="quantity-button" data-change-id="${item.id}" data-delta="1">
+                +
+              </button>
+            </div>
+            <strong>${formatWon(item.price * item.quantity)}</strong>
+          </div>
+        </article>
+      `
+    )
+    .join("");
+}
+
+function render() {
+  renderCategoryTabs();
+  renderMenu();
+  renderCart();
+}
+
+categoryTabs.addEventListener("click", (event) => {
+  const target = event.target.closest("[data-category]");
+
+  if (!target) {
+    return;
+  }
+
+  activeCategory = target.dataset.category;
+  render();
+});
+
+menuGrid.addEventListener("click", (event) => {
+  const target = event.target.closest("[data-add-id]");
+
+  if (!target) {
+    return;
+  }
+
+  const selectedItem = menuItems.find((item) => item.id === target.dataset.addId);
+
+  if (!selectedItem) {
+    return;
+  }
+
+  cartState = addItem(cartState, selectedItem);
+  setStatus(`${selectedItem.name}을(를) 장바구니에 담았습니다.`);
+  renderCart();
+});
+
+cartItems.addEventListener("click", (event) => {
+  const changeTarget = event.target.closest("[data-change-id]");
+  const removeTarget = event.target.closest("[data-remove-id]");
+
+  if (changeTarget) {
+    cartState = changeQuantity(
+      cartState,
+      changeTarget.dataset.changeId,
+      Number(changeTarget.dataset.delta)
+    );
+    setStatus("수량을 변경했습니다.");
+    renderCart();
+    return;
+  }
+
+  if (removeTarget) {
+    cartState = removeItem(cartState, removeTarget.dataset.removeId);
+    setStatus("메뉴를 장바구니에서 삭제했습니다.");
+    renderCart();
+  }
+});
+
+resetButton.addEventListener("click", () => {
+  cartState = clearCart();
+  setStatus("장바구니를 비웠습니다.");
+  renderCart();
+});
+
+checkoutButton.addEventListener("click", () => {
+  const summary = getCartSummary(cartState);
+
+  if (!summary.count) {
+    setStatus("먼저 메뉴를 1개 이상 선택해주세요.");
+    return;
+  }
+
+  setStatus(
+    `${summary.count}개 메뉴 주문 완료! 결제 예정 금액은 ${formatWon(summary.total)} 입니다.`
+  );
+});
+
+render();
