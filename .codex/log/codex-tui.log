+import test from "node:test";
+import assert from "node:assert/strict";
+
+import {
+  addItem,
+  changeQuantity,
+  clearCart,
+  createCartState,
+  formatWon,
+  getCartSummary,
+  removeItem
+} from "../src/cart.js";
+
+const bigMac = {
+  id: "big-mac",
+  name: "빅맥",
+  price: 6900
+};
+
+const fries = {
+  id: "fries",
+  name: "후렌치 후라이",
+  price: 2600
+};
+
+test("같은 메뉴를 다시 담으면 수량만 증가한다", () => {
+  let state = createCartState();
+  state = addItem(state, bigMac);
+  state = addItem(state, bigMac);
+
+  assert.equal(state.items.length, 1);
+  assert.equal(state.items[0].quantity, 2);
+  assert.deepEqual(getCartSummary(state), { count: 2, total: 13800 });
+});
+
+test("수량을 줄이다가 0이 되면 장바구니에서 제거된다", () => {
+  let state = createCartState();
+  state = addItem(state, fries);
+  state = changeQuantity(state, fries.id, -1);
+
+  assert.equal(state.items.length, 0);
+  assert.deepEqual(getCartSummary(state), { count: 0, total: 0 });
+});
+
+test("삭제와 초기화가 모두 정상 동작한다", () => {
+  let state = createCartState();
+  state = addItem(state, bigMac);
+  state = addItem(state, fries);
+  state = removeItem(state, bigMac.id);
+
+  assert.deepEqual(state.items.map((item) => item.id), [fries.id]);
+
+  state = clearCart(state);
+  assert.deepEqual(state, { items: [] });
+});
+
+test("원화 포맷을 보기 쉽게 출력한다", () => {
+  assert.equal(formatWon(12345), "₩12,345");
+});
