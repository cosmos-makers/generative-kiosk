+#!/usr/bin/env bash
+set -euo pipefail
+
+show_help() {
+  cat <<'EOF'
+Usage:
+  ./ralp-loop <prompt text...>
+
+What it does:
+  - runs `omx ralph` unattended for up to 5 hours by default
+  - launches Ralph inside a dedicated tmux session
+  - watches for dead/stalled runs and restarts them automatically
+  - writes logs and status files under `.omx/ralp-loop/`
+  - keeps macOS awake with `caffeinate` when available
+
+Environment variables:
+  RALP_LOOP_DURATION_SEC       Total runtime budget in seconds (default: 18000)
+  RALP_LOOP_POLL_SEC           Health-check interval in seconds (default: 20)
+  RALP_LOOP_STALL_SEC          Silence window before a nudge (default: 900)
+  RALP_LOOP_MAX_NUDGES         Nudges before force-restart (default: 3)
+  RALP_LOOP_RESTART_BACKOFF_SEC Restart delay after a failed run (default: 15)
+  RALP_LOOP_GRACEFUL_STOP_SEC  Wait after `omx cancel` before force-kill (default: 20)
+  RALP_LOOP_SESSION_PREFIX     tmux session prefix (default: ralph-loop)
+  RALP_LOOP_EXTRA_OMX_ARGS     Extra args appended to `omx ralph`
+  RALP_LOOP_NUDGE_MESSAGE      Message injected into a stalled tmux pane
+
+Examples:
+  ./ralp-loop "프로젝트 전체를 점검하고 타입 에러를 모두 해결해줘"
+  RALP_LOOP_DURATION_SEC=21600 ./ralp-loop "6시간까지 돌려줘"
+  RALP_LOOP_EXTRA_OMX_ARGS='--model gpt-5.4 --xhigh' ./ralp-loop "고난도 리팩터링"
+EOF
+}
+
+if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
+  show_help
+  exit 0
+fi
+
+if [[ $# -lt 1 ]]; then
+  show_help >&2
+  exit 1
+fi
+
+for required_bin in omx tmux node; do
+  if ! command -v "$required_bin" >/dev/null 2>&1; then
+    printf 'Missing required command: %s\n' "$required_bin" >&2
+    exit 1
+  fi
+done
+
+SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
+cd "$SCRIPT_DIR"
+
+if [[ -z "${RALP_LOOP_CAFFEINATED:-}" ]] && command -v caffeinate >/dev/null 2>&1; then
+  export RALP_LOOP_CAFFEINATED=1
+  exec caffeinate -dimsu "$0" "$@"
+fi
+
+PROMPT="$*"
+RUN_DIR="$SCRIPT_DIR/.omx/ralp-loop"
+mkdir -p "$RUN_DIR"
+
+RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"
+PROMPT_FILE="$RUN_DIR/$RUN_ID.prompt.txt"
+WRAPPER_LOG="$RUN_DIR/$RUN_ID.wrapper.log"
+STATUS_FILE="$RUN_DIR/latest-status.env"
+LATEST_WRAPPER_LINK="$RUN_DIR/latest.wrapper.log"
+LATEST_ATTEMPT_LINK="$RUN_DIR/latest.ralph.log"
+printf '%s\n' "$PROMPT" > "$PROMPT_FILE"
+touch "$WRAPPER_LOG"
+ln -sfn "$(basename "$WRAPPER_LOG")" "$LATEST_WRAPPER_LINK"
+
+DURATION_SEC="${RALP_LOOP_DURATION_SEC:-18000}"
+POLL_SEC="${RALP_LOOP_POLL_SEC:-20}"
+STALL_SEC="${RALP_LOOP_STALL_SEC:-900}"
+MAX_NUDGES="${RALP_LOOP_MAX_NUDGES:-3}"
+RESTART_BACKOFF_SEC="${RALP_LOOP_RESTART_BACKOFF_SEC:-15}"
+GRACEFUL_STOP_SEC="${RALP_LOOP_GRACEFUL_STOP_SEC:-20}"
+SESSION_PREFIX="${RALP_LOOP_SESSION_PREFIX:-ralph-loop}"
+EXTRA_OMX_ARGS="${RALP_LOOP_EXTRA_OMX_ARGS:-}"
+NUDGE_MESSAGE="${RALP_LOOP_NUDGE_MESSAGE:-Continue from current mode state. [OMX_TMUX_INJECT]}"
+BASE_OMX_ARGS="--yolo --madmax --no-alt-screen"
+
+START_EPOCH="$(date +%s)"
+DEADLINE_EPOCH=$((START_EPOCH + DURATION_SEC))
+ATTEMPT=0
+CURRENT_SESSION=""
+CURRENT_PANE=""
+CURRENT_ATTEMPT_LOG=""
+CURRENT_STATE_FILE=""
+CURRENT_PHASE=""
+
+log() {
+  local message="$1"
+  local line
+  line="$(date -u +'%Y-%m-%dT%H:%M:%SZ') $message"
+  printf '%s\n' "$line" | tee -a "$WRAPPER_LOG" >/dev/null
+}
+
+write_status() {
+  cat > "$STATUS_FILE" <<EOF
+RUN_ID=$RUN_ID
+START_EPOCH=$START_EPOCH
+DEADLINE_EPOCH=$DEADLINE_EPOCH
+ATTEMPT=$ATTEMPT
+SESSION_NAME=${CURRENT_SESSION:-}
+PANE_TARGET=${CURRENT_PANE:-}
+PROMPT_FILE=$PROMPT_FILE
+WRAPPER_LOG=$WRAPPER_LOG
+ATTEMPT_LOG=${CURRENT_ATTEMPT_LOG:-}
+STATE_FILE=${CURRENT_STATE_FILE:-}
+PHASE=${CURRENT_PHASE:-}
+UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
+EOF
+}
+
+json_field() {
+  local file="$1"
+  local field="$2"
+  node -e '
+    const fs = require("fs");
+    const file = process.argv[1];
+    const field = process.argv[2];
+    const data = JSON.parse(fs.readFileSync(file, "utf8"));
+    let value = data;
+    for (const key of field.split(".")) {
+      value = value == null ? undefined : value[key];
+    }
+    if (value == null) process.exit(2);
+    if (typeof value === "object") process.stdout.write(JSON.stringify(value));
+    else process.stdout.write(String(value));
+  ' "$file" "$field"
+}
+
+discover_latest_ralph_state_after() {
+  local min_epoch="$1"
+  local best_file=""
+  local best_mtime=0
+  local file=""
+  local mtime=0
+
+  if [[ ! -d "$SCRIPT_DIR/.omx/state" ]]; then
+    return 1
+  fi
+
+  while IFS= read -r file; do
+    [[ -z "$file" ]] && continue
+    mtime="$(stat -f '%m' "$file" 2>/dev/null || echo 0)"
+    if (( mtime >= min_epoch && mtime >= best_mtime )); then
+      best_mtime="$mtime"
+      best_file="$file"
+    fi
+  done < <(find "$SCRIPT_DIR/.omx/state" -type f -name 'ralph-state.json' 2>/dev/null)
+
+  [[ -n "$best_file" ]] || return 1
+  printf '%s\n' "$best_file"
+}
+
+tmux_session_exists() {
+  tmux has-session -t "$1" 2>/dev/null
+}
+
+graceful_stop_current_session() {
+  [[ -n "${CURRENT_SESSION:-}" ]] || return 0
+
+  if ! tmux_session_exists "$CURRENT_SESSION"; then
+    return 0
+  fi
+
+  log "graceful stop requested for $CURRENT_SESSION"
+  (cd "$SCRIPT_DIR" && omx cancel >/dev/null 2>&1) || true
+  sleep "$GRACEFUL_STOP_SEC"
+
+  if tmux_session_exists "$CURRENT_SESSION"; then
+    log "force killing tmux session $CURRENT_SESSION"
+    tmux kill-session -t "$CURRENT_SESSION" >/dev/null 2>&1 || true
+  fi
+}
+
+cleanup() {
+  if [[ -n "${CURRENT_SESSION:-}" ]] && tmux_session_exists "$CURRENT_SESSION"; then
+    graceful_stop_current_session
+  fi
+}
+
+trap cleanup INT TERM
+
+launch_attempt() {
+  ATTEMPT=$((ATTEMPT + 1))
+  CURRENT_SESSION="${SESSION_PREFIX}-${RUN_ID}-a${ATTEMPT}"
+  CURRENT_ATTEMPT_LOG="$RUN_DIR/${RUN_ID}-a${ATTEMPT}.ralph.log"
+  CURRENT_STATE_FILE=""
+  CURRENT_PHASE=""
+  touch "$CURRENT_ATTEMPT_LOG"
+  ln -sfn "$(basename "$CURRENT_ATTEMPT_LOG")" "$LATEST_ATTEMPT_LINK"
+
+  local command_text=""
+  local args_text="$BASE_OMX_ARGS"
+  if [[ -n "$EXTRA_OMX_ARGS" ]]; then
+    args_text="$args_text $EXTRA_OMX_ARGS"
+  fi
+
+  printf -v command_text 'cd %q && exec omx ralph %s -- "$(cat %q)"' \
+    "$SCRIPT_DIR" \
+    "$args_text" \
+    "$PROMPT_FILE"
+
+  log "launching attempt=$ATTEMPT session=$CURRENT_SESSION"
+  tmux new-session -d -s "$CURRENT_SESSION" "$command_text"
+  CURRENT_PANE="$(tmux list-panes -t "$CURRENT_SESSION" -F '#{pane_id}' | head -n 1)"
+  tmux pipe-pane -o -t "$CURRENT_PANE" "cat >> $(printf '%q' "$CURRENT_ATTEMPT_LOG")"
+  write_status
+}
+
+wait_for_completion_after_complete_phase() {
+  local wait_until=$(( $(date +%s) + 30 ))
+  while (( $(date +%s) < wait_until )); do
+    if ! tmux_session_exists "$CURRENT_SESSION"; then
+      return 0
+    fi
+    sleep 1
+  done
+  graceful_stop_current_session
+}
+
+monitor_attempt() {
+  local attempt_start_epoch
+  local last_output_epoch
+  local log_mtime=0
+  local nudges=0
+  local pane_dead=0
+  local now=0
+
+  attempt_start_epoch="$(date +%s)"
+  last_output_epoch="$attempt_start_epoch"
+
+  while (( $(date +%s) < DEADLINE_EPOCH )); do
+    now="$(date +%s)"
+
+    if [[ -f "$CURRENT_ATTEMPT_LOG" ]]; then
+      log_mtime="$(stat -f '%m' "$CURRENT_ATTEMPT_LOG" 2>/dev/null || echo 0)"
+      if (( log_mtime > last_output_epoch )); then
+        last_output_epoch="$log_mtime"
+        nudges=0
+      fi
+    fi
+
+    if [[ -z "$CURRENT_STATE_FILE" || ! -f "$CURRENT_STATE_FILE" ]]; then
+      CURRENT_STATE_FILE="$(discover_latest_ralph_state_after "$attempt_start_epoch" || true)"
+    fi
+
+    if [[ -n "$CURRENT_STATE_FILE" && -f "$CURRENT_STATE_FILE" ]]; then
+      CURRENT_PHASE="$(json_field "$CURRENT_STATE_FILE" current_phase 2>/dev/null || true)"
+      if [[ "$CURRENT_PHASE" == "complete" ]]; then
+        log "detected complete phase from $CURRENT_STATE_FILE"
+        write_status
+        wait_for_completion_after_complete_phase
+        return 0
+      fi
+    fi
+
+    if ! tmux_session_exists "$CURRENT_SESSION"; then
+      log "session $CURRENT_SESSION ended with phase=${CURRENT_PHASE:-unknown}"
+      write_status
+      return 1
+    fi
+
+    pane_dead="$(tmux display-message -p -t "$CURRENT_PANE" '#{pane_dead}' 2>/dev/null || echo 1)"
+    if [[ "$pane_dead" == "1" ]]; then
+      log "pane $CURRENT_PANE died with phase=${CURRENT_PHASE:-unknown}"
+      write_status
+      return 1
+    fi
+
+    if (( now - last_output_epoch >= STALL_SEC )); then
+      if (( nudges < MAX_NUDGES )); then
+        nudges=$((nudges + 1))
+        log "stall detected, sending nudge $nudges/$MAX_NUDGES"
+        tmux send-keys -t "$CURRENT_PANE" -l -- "$NUDGE_MESSAGE"
+        tmux send-keys -t "$CURRENT_PANE" C-m
+        last_output_epoch="$now"
+      else
+        log "stall persisted after $MAX_NUDGES nudges, restarting session"
+        graceful_stop_current_session
+        write_status
+        return 1
+      fi
+    fi
+
+    write_status
+    sleep "$POLL_SEC"
+  done
+
+  log "deadline reached"
+  write_status
+  return 2
+}
+
+log "starting run_id=$RUN_ID duration_sec=$DURATION_SEC"
+log "prompt_file=$PROMPT_FILE"
+
+while (( $(date +%s) < DEADLINE_EPOCH )); do
+  launch_attempt
+  if monitor_attempt; then
+    log "ralph completed successfully"
+    write_status
+    exit 0
+  fi
+
+  if (( $(date +%s) >= DEADLINE_EPOCH )); then
+    break
+  fi
+
+  log "restarting after backoff=${RESTART_BACKOFF_SEC}s"
+  sleep "$RESTART_BACKOFF_SEC"
+done
+
+graceful_stop_current_session
+log "stopped after duration budget exhausted"
+write_status
+exit 124
*** End Patch
